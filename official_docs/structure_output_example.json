{
    "$schema": "http://json-schema.org/draft/2020-12/schema#",
    "title": "SceneList",
    "type": "array",
    "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
            "scene_number",
            "scene_title",
            "image_prompt",
            "animation_prompt"
        ],
        "properties": {
            "scene_number": {
                "type": "integer",
                "minimum": 1,
                "description": "Порядковый номер сцены (целое положительное число)."
            },
            "scene_title": {
                "type": "string",
                "description": "Короткий заголовок сцены."
            },
            "image_prompt": {
                "type": "string",
                "description": "Текст-подсказка для генерации статичного кадра (описание композиции/освещения/стиля)."
            },
            "animation_prompt": {
                "type": "string",
                "description": "Текст-подсказка для анимации (как должны двигаться элементы)."
            }
        }
    }
}